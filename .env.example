# Required: Your TravelCode API base URL
TRAVELCODE_API_BASE_URL=https://api.travel-code.com/v1

# Required: Your Bearer token from the TravelCode platform
TRAVELCODE_API_TOKEN=your-token-here

# Optional: Polling configuration for flight search
# TRAVELCODE_POLL_INTERVAL_MS=2000
# TRAVELCODE_POLL_TIMEOUT_MS=90000
